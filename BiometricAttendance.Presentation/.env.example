# ── Database ──────────────────────────────────────────────────────────────────
# Strong password: min 8 chars, uppercase, lowercase, digit, special character
DB_PASSWORD=YourStrong@Password123

# ── JWT ───────────────────────────────────────────────────────────────────────
# Random secret key (min 32 characters recommended)
JWT_KEY=YourSuperSecretKeyHereMakeItLongEnough32Chars!

# ── Serial Port ───────────────────────────────────────────────────────────────
# On Linux containers use /dev/ttyUSB0 or /dev/ttyS0 (not COM3)
# If running on Linux host, also add devices mapping in docker-compose.yml
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=9600
